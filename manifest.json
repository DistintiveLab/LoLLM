{
    "manifest_version": 2,
    "name": "LoLLM",
    "version": "1.0.0",
    "description": "LoLLM (Leaf open-LLM) - a privacy-respecting LLM extension that runs locally in your browser.",
    "permissions": [
        "storage",
        "contextMenus",
        "activeTab",
        "<all_urls>"
    ],
    "background": {
        "page": "background.html"
    },
    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "popup/LoLLM_16.png",
            "48": "popup/LoLLM_48.png",
            "128": "popup/LoLLM_128.png"
        }
    },
    "icons": {
        "16": "popup/LoLLM_16.png",
        "48": "popup/LoLLM_48.png",
        "128": "popup/LoLLM_128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "all_frames": true,
            "js": [
                "scripts/content-script.js"
            ]
        }
    ],
    "content_security_policy": "script-src 'self'; object-src 'self';",
    "browser_specific_settings": {
        "gecko": {
            "id": "lollm@bthink.bgu.ac.il",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"],
                "optional": []
            }
        }
    }
}

